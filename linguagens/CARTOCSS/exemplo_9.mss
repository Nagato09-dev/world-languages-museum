#layer {
  // Manipulação de String (Maiúsculas) - não diretamente aplicável para estilização
  // Pode ser usado em labels, mas não é uma operação de estilo.
  // Exemplo de uso de texto em label (se suportado pelo renderizador):
  text-name: '[name]';
  text-transform: uppercase; // Se o renderizador suportar
}
